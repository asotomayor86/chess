# Copia este archivo a .env.local y rellena los valores.

# Cadena de conexión a Neon (Postgres). En Vercel se inyecta automáticamente al
# crear la base de datos desde Storage. En local cópiala desde el panel de Neon.
DATABASE_URL=postgresql://usuario:password@host.neon.tech/dbname?sslmode=require

# --- Integración con el Hub de Juegos en Familia (SSO + salas) ---------------

# URL base del hub (sin barra final). Se usa para el login SSO, leer la sala y
# devolver el resultado. Pública (NEXT_PUBLIC_) porque el cliente también la usa.
NEXT_PUBLIC_HUB_URL=https://one-page-to-rule-them-all.vercel.app

# Secreto compartido con el hub para devolver el resultado de la partida.
# DEBE ser EXACTAMENTE el mismo valor que HUB_RESULT_SECRET del hub. Solo backend.
HUB_RESULT_SECRET=

# Secreto propio del juego para firmar la cookie de sesión (aj_user). 32+ chars.
# Si no se define, cae a HUB_RESULT_SECRET. Solo backend.
SESSION_SECRET=

# Clave para el panel /admin (gestión de salas). Si no se define, admin deshabilitado.
ADMIN_PASSWORD=
